{
  "name": "leadflow-backend",
  "version": "2.0.0",
  "description": "LeadFlow-AI Backend Service — Production Multi-Tenant SaaS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/queues/workers/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:reset": "prisma migrate reset --force",
    "db:setup": "prisma migrate deploy && node prisma/seed.js",
    "db:studio": "prisma studio",
    "test": "node --test tests/*.test.js",
    "test:e2e-call": "node scripts/e2e-call-test.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@sendgrid/mail": "^8.1.1",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cloudinary": "^2.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.10",
    "pg": "^8.21.0",
    "razorpay": "^2.9.2",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "twilio": "^4.22.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
