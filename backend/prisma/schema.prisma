datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  logo                String?
  industry            String?
  plan                Plan      @default(STARTER)
  planExpiresAt       DateTime?
  aiCallsUsed         Int       @default(0)
  aiCallsLimit        Int       @default(20)
  isActive            Boolean   @default(true)
  razorpaySubId       String?
  razorpayCustomerId  String?
  whatsappToken       String?
  whatsappPhoneId     String?
  exotelApiKey        String?
  exotelApiToken      String?
  exotelSubdomain     String?
  aiCallerEnabled     Boolean   @default(false)
  aiCallerLanguage    String    @default("hindi")
  aiCallerVoice       String    @default("meera")
  qualifyQuestions    Json?
  callingHoursStart   String    @default("09:00")
  callingHoursEnd     String    @default("20:00")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  users               User[]
  leads               Lead[]
  pipelines           Pipeline[]
  calls               Call[]
  whatsappMessages    WhatsappMessage[]
  automations         Automation[]
  integrations        Integration[]
  subscriptions       Subscription[]
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

model User {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  email            String
  passwordHash     String
  role             UserRole     @default(AGENT)
  avatar           String?
  phone            String?
  isActive         Boolean      @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  assignedLeads    Lead[]       @relation("AssignedLeads")
  activities       Activity[]

  @@unique([email, organizationId])
  @@index([organizationId])
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

model Pipeline {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  stages         Stage[]

  @@index([organizationId])
}

model Stage {
  id         String   @id @default(uuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name       String
  color      String   @default("#6366f1")
  order      Int
  leads      Lead[]

  @@index([pipelineId])
}

model Lead {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedToId    String?
  assignedTo      User?        @relation("AssignedLeads", fields: [assignedToId], references: [id])
  stageId         String?
  stage           Stage?       @relation(fields: [stageId], references: [id])
  name            String
  email           String?
  phone           String
  whatsapp        String?
  company         String?
  source          LeadSource   @default(MANUAL)
  sourceDetail    String?
  budget          String?
  timeline        String?
  requirement     String?
  location        String?
  decisionMaker   Boolean?
  additionalNotes String?
  score           Int?
  scoreLabel      ScoreLabel?
  scoreReason     String?
  scoredAt        DateTime?
  status          LeadStatus   @default(NEW)
  priority        Priority     @default(MEDIUM)
  isQualified     Boolean      @default(false)
  consentGiven    Boolean      @default(false)
  consentAt       DateTime?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  closedAt        DateTime?
  closedReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  calls           Call[]
  whatsappMessages WhatsappMessage[]
  activities      Activity[]
  notes           Note[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, scoreLabel])
  @@index([organizationId, source])
  @@index([phone, organizationId])
}

enum LeadSource {
  MANUAL
  WHATSAPP
  WEBSITE_FORM
  FACEBOOK_AD
  INDIAMART
  JUSTDIAL
  GOOGLE_AD
  REFERRAL
  CSV_IMPORT
  API
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  UNQUALIFIED
}

enum ScoreLabel {
  HOT
  WARM
  COLD
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Call {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  exotelCallSid  String?       @unique
  direction      CallDirection @default(OUTBOUND)
  fromNumber     String
  toNumber       String
  status         CallStatus    @default(INITIATED)
  duration       Int?
  recordingUrl   String?
  transcript     Json?
  summary        String?
  extractedData  Json?
  aiScore        Int?
  aiScoreLabel   ScoreLabel?
  aiScoreReason  String?
  language       String        @default("hindi")
  triggeredAt    DateTime      @default(now())
  answeredAt     DateTime?
  endedAt        DateTime?
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([leadId])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
}

model WhatsappMessage {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  waMessageId    String?      @unique
  direction      String
  type           String
  content        String
  templateName   String?
  status         String       @default("sent")
  sentAt         DateTime     @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?

  @@index([organizationId])
  @@index([leadId])
}

model Automation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  isActive       Boolean      @default(true)
  trigger        Json
  steps          Json
  executionCount Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Activity {
  id             String   @id @default(uuid())
  organizationId String
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  type           String
  description    String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([leadId])
  @@index([organizationId])
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Subscription {
  id                 String       @id @default(uuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan
  status             String
  amount             Float
  currency           String       @default("INR")
  razorpaySubId      String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime     @default(now())

  @@index([organizationId])
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  isActive       Boolean      @default(true)
  config         Json
  webhookUrl     String?
  lastSyncAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}
