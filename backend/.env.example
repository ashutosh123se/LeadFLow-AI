# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_DOMAIN=http://localhost:5000
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Auth (generate with: openssl rand -hex 32) ───────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI / Voice pipeline ─────────────────────────────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai

# ─── Exotel telephony ───────────────────────────────────────────────────────
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=
EXOTEL_CALLER_ID=
EXOTEL_APP_ID=
# HMAC secret for verifying inbound Exotel webhooks (generate random 32+ bytes)
EXOTEL_WEBHOOK_SECRET=

# ─── Meta WhatsApp Business API ─────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ─── Razorpay billing ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Set ONLY for explicit local billing sandbox tests (never in production)
BILLING_MOCK_MODE=false

# ─── Email ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=
FROM_NAME=LeadFlow-AI

# ─── Optional integrations ──────────────────────────────────────────────────
FACEBOOK_PAGE_ACCESS_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Platform seed (first super-admin) ──────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
